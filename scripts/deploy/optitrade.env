# OptiTrade Engine Environment Configuration
# This file is used by Docker Compose and Systemd to configure the engine at deployment time.

# DPDK Core Mask (e.g., '0' for core 0, '0,2' for cores 0 and 2)
OPTITRADE_CORE_MASK=0

# The name of the AF_PACKET virtual or physical interface to bind to
OPTITRADE_IFACE=ot_eng

# Number of Queue Pairs
OPTITRADE_QPAIRS=1

# Memory pool ops name (ring_mp_mc is default for memory-backed)
OPTITRADE_MBUF_POOL=ring_mp_mc
